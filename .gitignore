node_modules/
.next/
out/
build/
dist/

# un-ignore lib/ which gets swept up by Python-oriented global gitignores
!lib/
!lib/**
# un-ignore the public/icons directory — the global ~/.gitignore_global
# has `Icon?` (for macOS's Icon\r marker) which case-insensitively eats
# any path containing 'icon' (including public/icons/*). Whitelist the
# whole public/ subtree since everything there is a PWA asset we want
# shipped.
!public/
!public/**

# env
.env
.env.local
.env*.local

# database & uploads
prisma/dev.db
prisma/dev.db-journal
# /uploads/ NOT uploads/ — the leading slash anchors the match to the
# project root, so we keep ignoring the local photo cache without also
# swallowing app/api/uploads/ (the Next.js route) or anything else
# whose name happens to include "uploads".
/uploads/

# supabase cli local state (config.toml at supabase/ root is committed;
# everything in .supabase/ is machine-specific)
.supabase/
supabase/.temp/
supabase/.branches/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# system
.DS_Store
*.pem

# editor / local agent state
.vscode/
.idea/
.claude/

# ts
*.tsbuildinfo
next-env.d.ts
.vercel
