node_modules/
.next/
out/
build/
dist/

# un-ignore lib/ which gets swept up by Python-oriented global gitignores
!lib/
!lib/**

# env
.env
.env.local
.env*.local

# database & uploads
prisma/dev.db
prisma/dev.db-journal
uploads/

# supabase cli local state (config.toml at supabase/ root is committed;
# everything in .supabase/ is machine-specific)
.supabase/
supabase/.temp/
supabase/.branches/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# system
.DS_Store
*.pem

# editor / local agent state
.vscode/
.idea/
.claude/

# ts
*.tsbuildinfo
next-env.d.ts
.vercel
